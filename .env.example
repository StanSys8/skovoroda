# Copy to .env and adjust. Every variable has a sane default —
# an empty .env (or none at all) gives a localhost-only setup.

# Interface to publish ports on.
# 127.0.0.1 = this machine only (default, recommended).
# 0.0.0.0   = all interfaces / LAN access. Add your own auth layer first!
BIND_HOST=127.0.0.1

# Published ports on the host.
UI_PORT=8080
API_PORT=3900
DB_PORT=5432

# PostgreSQL credentials.
DB_USER=skovoroda
DB_PASSWORD=skovoroda
DB_NAME=skovoroda
