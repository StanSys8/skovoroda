# Copy to .env and adjust. `.env` is gitignored.
#
# For a hardened deployment set API_KEY and DB_PASSWORD to strong random
# values, e.g.:
#     openssl rand -hex 32

# Interface to publish ports on.
# 127.0.0.1 = this machine only (default, recommended — keep it).
# 0.0.0.0   = all interfaces / LAN access. Add your own auth layer first!
BIND_HOST=127.0.0.1

# Published ports on the host.
UI_PORT=8080
API_PORT=3900
DB_PORT=5432

# --- Auth ---------------------------------------------------------------
# Shared secret required on every /api request (header X-API-Key or
# Authorization: Bearer). Empty = auth DISABLED (fine for a throwaway
# local run; set it before exposing anything). The frontend bakes this in
# at build time, so run `docker compose up --build` after changing it.
API_KEY=

# Browser origin allowed to call the API (must match UI_PORT / BIND_HOST).
CORS_ORIGIN=http://localhost:8080

# --- PostgreSQL ---------------------------------------------------------
# DB_PASSWORD is REQUIRED (no default) — do not ship skovoroda/skovoroda.
DB_USER=skovoroda
DB_PASSWORD=
DB_NAME=skovoroda
